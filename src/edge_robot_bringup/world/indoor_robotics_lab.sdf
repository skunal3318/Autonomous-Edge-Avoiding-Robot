    </model>
    <model name="lab_stool_seat">
      <static>true</static><pose>-4.5 2.0 0.65 0 0 0</pose>
      <link name="l">
        <collision name="c"><geometry><cylinder><radius>0.2</radius><length>0.05</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.2</radius><length>0.05</length></cylinder></geometry>
