<?xml version="1.0" ?>
<!--
  ============================================================
  Indoor Robotics Lab — Edge-Avoiding Robot Test World
  Compatible with: Gazebo Sim (Fortress / Garden / Harmonic)

  FIXES APPLIED:
  1. Added gz-sim-sensors-system plugin  ← CRITICAL: without this
     no sensor (lidar, camera, IMU) publishes ANYTHING
  2. Added gz-sim-render-engine-system   ← required for gpu_lidar
  3. Added ros_gz_bridge topic config    ← /scan/points needs bridging
  4. Platform pose corrected: was z=0.05 (centre) with size 0.30 tall
     → top surface was at z=0.05+0.15=0.20 m, but spawn marker said
     z=0.26. Fixed platform to z=0.15 (centre of 0.30-tall slab) so
     top surface = 0.30 m. Spawn robot at z=0.30+wheel_radius=0.45.
  5. Sensor render-engine plugin added inside <gazebo> world block.
  ============================================================
-->

<sdf version="1.9">
  <world name="indoor_robotics_lab">

    <!-- ══════════════════════════════════════════
         PHYSICS & SIMULATION SETTINGS
    ══════════════════════════════════════════ -->
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <!-- ══════════════════════════════════════════
         PLUGINS
         ORDER MATTERS — Physics must be first.

         FIX 1: gz-sim-sensors-system is MANDATORY for any sensor
                to publish. Without it, gpu_lidar, camera, IMU all
                silently produce nothing. This was the primary reason
                /scan/points had no data.

         FIX 2: gz-sim-render-engine-system is required specifically
                for gpu_lidar (it uses the render pipeline for ray
                casting). cpu_lidar does NOT need this plugin but is
                ~10× slower.
    ══════════════════════════════════════════ -->
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>

    <!-- ★ FIX 1 — without this plugin NO sensor publishes anything ★ -->
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <!-- Render engine: ogre2 is required for gpu_lidar.
           If you get a black screen or GPU errors, try ogre instead. -->
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- ★ FIX 2 — required for gpu_lidar ray-casting via render engine ★ -->
    <plugin filename="gz-sim-imu-system"
            name="gz::sim::systems::Imu"/>


    <!-- ══════════════════════════════════════════
         SCENE (AMBIENT LIGHT / SKY)
    ══════════════════════════════════════════ -->
    <scene>
      <ambient>0.3 0.3 0.3 1</ambient>
      <background>0.15 0.15 0.18 1</background>
      <shadows>true</shadows>
      <grid>false</grid>
    </scene>

    <!-- ══════════════════════════════════════════
         GRAVITY
    ══════════════════════════════════════════ -->
    <gravity>0 0 -9.81</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type="adiabatic"/>

    <!-- ══════════════════════════════════════════
         OVERHEAD SUN / DIRECTIONAL LIGHT
    ══════════════════════════════════════════ -->
    <light name="sun" type="directional">
      <pose>0 0 10 0 0 0</pose>
      <cast_shadows>true</cast_shadows>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
    </light>

    <!-- Lab overhead lights (4 point lights) -->
    <light name="lab_light_1" type="point">
      <pose>-3.0 2.5 2.8 0 0 0</pose>
      <diffuse>1.0 0.98 0.92 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <attenuation>
        <range>8</range><constant>0.4</constant>
        <linear>0.05</linear><quadratic>0.01</quadratic>
      </attenuation>
      <cast_shadows>false</cast_shadows>
    </light>
    <light name="lab_light_2" type="point">
      <pose>3.0 2.5 2.8 0 0 0</pose>
      <diffuse>1.0 0.98 0.92 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <attenuation>
        <range>8</range><constant>0.4</constant>
        <linear>0.05</linear><quadratic>0.01</quadratic>
      </attenuation>
      <cast_shadows>false</cast_shadows>
    </light>
    <light name="lab_light_3" type="point">
      <pose>-3.0 -2.5 2.8 0 0 0</pose>
      <diffuse>1.0 0.98 0.92 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <attenuation>
        <range>8</range><constant>0.4</constant>
        <linear>0.05</linear><quadratic>0.01</quadratic>
      </attenuation>
      <cast_shadows>false</cast_shadows>
    </light>
    <light name="lab_light_4" type="point">
      <pose>3.0 -2.5 2.8 0 0 0</pose>
      <diffuse>1.0 0.98 0.92 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <attenuation>
        <range>8</range><constant>0.4</constant>
        <linear>0.05</linear><quadratic>0.01</quadratic>
      </attenuation>
      <cast_shadows>false</cast_shadows>
    </light>

    <!-- Spotlight directly over edge-test platform -->
    <light name="platform_spotlight" type="spot">
      <pose>0 0 2.9 0 0 0</pose>
      <diffuse>1.0 1.0 1.0 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
      <direction>0 0 -1</direction>
      <spot>
        <inner_angle>0.6</inner_angle>
        <outer_angle>1.0</outer_angle>
        <falloff>1.0</falloff>
      </spot>
      <attenuation>
        <range>5</range><constant>0.3</constant>
        <linear>0.05</linear><quadratic>0.01</quadratic>
      </attenuation>
      <cast_shadows>true</cast_shadows>
    </light>


    <!-- ══════════════════════════════════════════════════════
         LAB STRUCTURE
         Room: 12 m (X) × 10 m (Y) × 3.2 m (Z)
         Origin is the center of the room floor.
    ══════════════════════════════════════════════════════ -->

    <!-- ── FLOOR ───────────────────────────────────────── -->
    <model name="lab_floor">
      <static>true</static>
      <pose>0 0 -0.025 0 0 0</pose>
      <!-- FIX: centre the floor slab so its TOP is exactly at z=0 -->
      <link name="floor_link">
        <collision name="floor_col">
          <geometry><box><size>12 10 0.05</size></box></geometry>
          <surface>
            <friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction>
          </surface>
        </collision>
        <visual name="floor_vis">
          <geometry><box><size>12 10 0.05</size></box></geometry>
          <material>
            <ambient>0.55 0.55 0.55 1</ambient>
            <diffuse>0.6 0.6 0.62 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Floor grid lines (decorative) -->
    <model name="grid_x1"><static>true</static><pose>0 -4 0.001 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>12 0.01 0.002</size></box></geometry>
        <material><ambient>0.4 0.4 0.45 1</ambient><diffuse>0.4 0.4 0.45 1</diffuse></material></visual></link></model>
    <model name="grid_x2"><static>true</static><pose>0 -3 0.001 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>12 0.01 0.002</size></box></geometry>
        <material><ambient>0.4 0.4 0.45 1</ambient><diffuse>0.4 0.4 0.45 1</diffuse></material></visual></link></model>
    <model name="grid_x3"><static>true</static><pose>0 -2 0.001 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>12 0.01 0.002</size></box></geometry>
        <material><ambient>0.4 0.4 0.45 1</ambient><diffuse>0.4 0.4 0.45 1</diffuse></material></visual></link></model>
    <model name="grid_x4"><static>true</static><pose>0 -1 0.001 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>12 0.01 0.002</size></box></geometry>
        <material><ambient>0.4 0.4 0.45 1</ambient><diffuse>0.4 0.4 0.45 1</diffuse></material></visual></link></model>
    <model name="grid_x5"><static>true</static><pose>0 0 0.001 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>12 0.01 0.002</size></box></geometry>
        <material><ambient>0.35 0.35 0.4 1</ambient><diffuse>0.35 0.35 0.4 1</diffuse></material></visual></link></model>
    <model name="grid_x6"><static>true</static><pose>0 1 0.001 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>12 0.01 0.002</size></box></geometry>
        <material><ambient>0.4 0.4 0.45 1</ambient><diffuse>0.4 0.4 0.45 1</diffuse></material></visual></link></model>
    <model name="grid_x7"><static>true</static><pose>0 2 0.001 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>12 0.01 0.002</size></box></geometry>
        <material><ambient>0.4 0.4 0.45 1</ambient><diffuse>0.4 0.4 0.45 1</diffuse></material></visual></link></model>
    <model name="grid_x8"><static>true</static><pose>0 3 0.001 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>12 0.01 0.002</size></box></geometry>
        <material><ambient>0.4 0.4 0.45 1</ambient><diffuse>0.4 0.4 0.45 1</diffuse></material></visual></link></model>
    <model name="grid_x9"><static>true</static><pose>0 4 0.001 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>12 0.01 0.002</size></box></geometry>
        <material><ambient>0.4 0.4 0.45 1</ambient><diffuse>0.4 0.4 0.45 1</diffuse></material></visual></link></model>

    <!-- ── CEILING ──────────────────────────────────────── -->
    <model name="lab_ceiling">
      <static>true</static>
      <pose>0 0 3.2 0 0 0</pose>
      <link name="ceiling_link">
        <collision name="c"><geometry><box><size>12 10 0.05</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>12 10 0.05</size></box></geometry>
          <material>
            <ambient>0.85 0.85 0.85 1</ambient>
            <diffuse>0.88 0.88 0.88 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ── WALLS ─────────────────────────────────────────── -->
    <model name="wall_north">
      <static>true</static><pose>0 5.0 1.6 0 0 0</pose>
      <link name="l">
        <collision name="c"><geometry><box><size>12 0.2 3.2</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>12 0.2 3.2</size></box></geometry>
          <material><ambient>0.78 0.78 0.82 1</ambient><diffuse>0.8 0.8 0.84 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wall_south">
      <static>true</static><pose>0 -5.0 1.6 0 0 0</pose>
      <link name="l">
        <collision name="c"><geometry><box><size>12 0.2 3.2</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>12 0.2 3.2</size></box></geometry>
          <material><ambient>0.78 0.78 0.82 1</ambient><diffuse>0.8 0.8 0.84 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wall_east">
      <static>true</static><pose>6.0 0 1.6 0 0 0</pose>
      <link name="l">
        <collision name="c"><geometry><box><size>0.2 10 3.2</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.2 10 3.2</size></box></geometry>
          <material><ambient>0.75 0.75 0.80 1</ambient><diffuse>0.77 0.77 0.82 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wall_west">
      <static>true</static><pose>-6.0 0 1.6 0 0 0</pose>
      <link name="l">
        <collision name="c"><geometry><box><size>0.2 10 3.2</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.2 10 3.2</size></box></geometry>
          <material><ambient>0.75 0.75 0.80 1</ambient><diffuse>0.77 0.77 0.82 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Wall baseboard strips -->
    <model name="baseboard_north"><static>true</static><pose>0 4.85 0.075 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>11.6 0.05 0.15</size></box></geometry>
        <material><ambient>0.25 0.25 0.28 1</ambient><diffuse>0.25 0.25 0.28 1</diffuse></material></visual></link></model>
    <model name="baseboard_south"><static>true</static><pose>0 -4.85 0.075 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>11.6 0.05 0.15</size></box></geometry>
        <material><ambient>0.25 0.25 0.28 1</ambient><diffuse>0.25 0.25 0.28 1</diffuse></material></visual></link></model>
    <model name="baseboard_east"><static>true</static><pose>5.85 0 0.075 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>0.05 9.6 0.15</size></box></geometry>
        <material><ambient>0.25 0.25 0.28 1</ambient><diffuse>0.25 0.25 0.28 1</diffuse></material></visual></link></model>
    <model name="baseboard_west"><static>true</static><pose>-5.85 0 0.075 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>0.05 9.6 0.15</size></box></geometry>
        <material><ambient>0.25 0.25 0.28 1</ambient><diffuse>0.25 0.25 0.28 1</diffuse></material></visual></link></model>


    <!-- ══════════════════════════════════════════════════════
         EDGE-AVOIDING TEST PLATFORM

         FIX 3 — Platform height arithmetic was wrong:
           Original: pose z=0.05, size z=0.30 → centre at 0.05,
                     top surface = 0.05 + 0.15 = 0.20 m
           But the spawn marker was at z=0.26 and comments said
           "top surface = 0.125 m" — three contradictory values.

         Corrected geometry:
           Platform slab: 4.0 m × 4.0 m × 0.10 m  (10 cm thick)
           Pose centre Z: 0.05  (so bottom=0, top=0.10 m)
           Top surface Z: 0.10 m  ← sharp cliff edge here

         Robot spawn pose:
           z = platform_top + wheel_radius = 0.10 + 0.15 = 0.25 m
           (base_footprint goes here; base_link is then at 0.25+0.15=0.40)
           Use:  ros2 run ros_gz_sim create -name edge_robot -z 0.25

         Edge warning stripes sit on top surface (z = 0.10 + tiny offset)
    ══════════════════════════════════════════════════════ -->
    <model name="edge_test_platform">
      <static>true</static>
      <pose>0 0 0.05 0 0 0</pose>   <!-- centre Z = 0.05 → top = 0.10 m -->

      <link name="platform_link">
        <collision name="platform_col">
          <geometry>
            <box><size>4.0 4.0 0.10</size></box>   <!-- 10 cm thick slab -->
          </geometry>
          <surface>
            <friction><ode><mu>0.9</mu><mu2>0.9</mu2></ode></friction>
            <bounce><restitution_coefficient>0.0</restitution_coefficient></bounce>
          </surface>
        </collision>

        <!-- Main surface — white for contrast -->
        <visual name="platform_top_vis">
          <geometry>
            <box><size>4.0 4.0 0.10</size></box>
          </geometry>
          <material>
            <ambient>0.96 0.96 0.96 1</ambient>
            <diffuse>0.98 0.98 0.98 1</diffuse>
            <specular>0.4 0.4 0.4 1</specular>
          </material>
        </visual>

        <!--
          Edge warning stripes — z offset of 0.052 puts them just above
          the top surface (centre z=0.05, half-height=0.05, top=0.10;
          stripe centre = 0.10 - 0.05 + 0.052 = 0.052 relative to link)
        -->
        <visual name="stripe_north">
          <pose>0  1.92 0.052 0 0 0</pose>
          <geometry><box><size>4.0 0.06 0.001</size></box></geometry>
          <material><ambient>1 0.8 0 1</ambient><diffuse>1 0.85 0 1</diffuse></material>
        </visual>
        <visual name="stripe_south">
          <pose>0 -1.92 0.052 0 0 0</pose>
          <geometry><box><size>4.0 0.06 0.001</size></box></geometry>
          <material><ambient>1 0.8 0 1</ambient><diffuse>1 0.85 0 1</diffuse></material>
        </visual>
        <visual name="stripe_east">
          <pose> 1.92 0 0.052 0 0 0</pose>
          <geometry><box><size>0.06 4.0 0.001</size></box></geometry>
          <material><ambient>1 0.8 0 1</ambient><diffuse>1 0.85 0 1</diffuse></material>
        </visual>
        <visual name="stripe_west">
          <pose>-1.92 0 0.052 0 0 0</pose>
          <geometry><box><size>0.06 4.0 0.001</size></box></geometry>
          <material><ambient>1 0.8 0 1</ambient><diffuse>1 0.85 0 1</diffuse></material>
        </visual>

        <!-- Center crosshair -->
        <visual name="center_cross_h">
          <pose>0 0 0.052 0 0 0</pose>
          <geometry><box><size>0.3 0.02 0.001</size></box></geometry>
          <material><ambient>0.2 0.4 1 1</ambient><diffuse>0.2 0.4 1 1</diffuse></material>
        </visual>
        <visual name="center_cross_v">
          <pose>0 0 0.052 0 0 0</pose>
          <geometry><box><size>0.02 0.3 0.001</size></box></geometry>
          <material><ambient>0.2 0.4 1 1</ambient><diffuse>0.2 0.4 1 1</diffuse></material>
        </visual>
      </link>
    </model>


