    </model>
    <model name="lab_stool_pole">
      <static>true</static><pose>-4.5 2.0 0.325 0 0 0</pose>
      <link name="l">
        <collision name="c"><geometry><cylinder><radius>0.03</radius><length>0.65</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.03</radius><length>0.65</length></cylinder></geometry>
          <material><ambient>0.6 0.6 0.65 1</ambient><diffuse>0.6 0.6 0.65 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Storage shelves -->
    <model name="shelf_back">
      <static>true</static><pose>5.4 -3.0 1.0 0 0 0</pose>
      <link name="l">
        <collision name="c"><geometry><box><size>0.05 2.0 2.0</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.05 2.0 2.0</size></box></geometry>
          <material><ambient>0.55 0.45 0.35 1</ambient><diffuse>0.55 0.45 0.35 1</diffuse></material></visual>
