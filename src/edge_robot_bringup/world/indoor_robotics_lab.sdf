    <!-- ══════════════════════════════════════════════════════
         ROBOT SPAWN ZONE MARKER

         FIX 4 — Corrected spawn pose:
           platform_top = 0.10 m
           robot base_footprint should be at z = 0.10 + ε (just on surface)
           base_link is lifted by wheel_radius=0.15 in the joint,
           so spawn: -z 0.10  (base_footprint lands exactly on platform)

         Command to spawn robot:
           ros2 run ros_gz_sim create \
             -name edge_robot \
             -topic robot_description \
             -x 0 -y 0 -z 0.10
    ══════════════════════════════════════════════════════ -->
    <model name="robot_spawn_marker">
      <static>true</static>
      <pose>0 0 0.101 0 0 0</pose>   <!-- just above platform top -->
      <link name="l">
        <visual name="v">
          <geometry><cylinder><radius>0.03</radius><length>0.002</length></cylinder></geometry>
          <material>
            <ambient>0.0 0.8 1.0 0.7</ambient>
