<?xml version="1.0"?>
<robot name="edge_robot" xmlns:xacro="https://www.ros.org/wiki/xacro">

    <xacro:property name="pi_const" value="3.14159265" />  

    <xacro:property name="length" value="1.0"/>
    <xacro:property name="height" value="0.3"/>
    <xacro:property name="breadth" value="0.6"/>
    <xacro:property name="radius" value="0.15"/>
    <xacro:property name="d" value="0.1"/>

    
    <xacro:property name="body_z" value="${radius + height/2}"/>  
    <xacro:property name="body_top_z" value="${radius + height}"/>  
    <xacro:property name="wheel_x" value="${length/2 - radius}"/>  
    <xacro:property name="wheel_y" value="${breadth/2 + d/2}"/>  

    <xacro:property name="density_body" value="2710.0"/>
    <xacro:property name="density_wheel" value="2710.0"/>

    <xacro:property name="m_body"  value="${density_body  * length * breadth * height}"/>
    <xacro:property name="m_wheel" value="${density_wheel * pi_const * radius * radius * d}"/>

    <xacro:property name="Ix_box" value="${(1.0/12.0)*m_body*(height*height + breadth*breadth)}"/>
    <xacro:property name="Iy_box" value="${(1.0/12.0)*m_body*(length*length + height*height)}" />
    <xacro:property name="Iz_box" value="${(1.0/12.0)*m_body*(length*length + breadth*breadth)}"/>

    <xacro:property name="Iz_wheel" value="${0.5  * m_wheel * radius * radius}"/>
    <xacro:property name="I_wheel"  value="${(1.0/12.0)*m_wheel*(3.0*radius*radius + d*d)}"/>  

    <xacro:property name="m_lidar"    value="0.2"/>
    <xacro:property name="Iz_lidar"   value="${0.5  * m_lidar * 0.1 * 0.1}"/>
    <xacro:property name="Ixy_lidar"  value="${(1.0/12.0)*m_lidar*(3.0*0.1*0.1 + 0.1*0.1)}"/>

    
    <xacro:macro name="inertia_body">
        <inertial>
            <origin xyz="0 0 ${height/2}" rpy="0 0 0"/>
            <mass value="${m_body}"/>
            <inertia ixx="${Ix_box}" ixy="0.0" ixz="0.0"
                     iyy="${Iy_box}" iyz="0.0"
                     izz="${Iz_box}"/>
        </inertial>
    </xacro:macro>

    <xacro:macro name="inertia_wheel">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${m_wheel}"/>
            <inertia ixx="${I_wheel}"  ixy="0.0" ixz="0.0"
                     iyy="${Iz_wheel}" iyz="0.0"
                     izz="${I_wheel}"/>
        </inertial>
    </xacro:macro>

    <xacro:macro name="inertia_lidar">
        <inertial>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <mass value="${m_lidar}"/>
            <inertia ixx="${Ixy_lidar}" ixy="0.0" ixz="0.0"
                     iyy="${Ixy_lidar}" iyz="0.0"
                     izz="${Iz_lidar}"/>
        </inertial>
    </xacro:macro>

    <link name="base_footprint"/>

    <joint name="base_link_joint" type="fixed">
        <origin xyz="0 0 ${radius}" rpy="0 0 0"/>
        <parent link="base_footprint"/>
        <child  link="base_link"/>
    </joint>


    <link name="base_link">
        <visual>
            <origin xyz="0 0 ${height/2}" rpy="0 0 0"/>
            <geometry>
                <box size="${length} ${breadth} ${height}"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 ${height/2}" rpy="0 0 0"/>
            <geometry>
                <box size="${length} ${breadth} ${height}"/>
            </geometry>
        </collision>
        <xacro:inertia_body/>
    </link>

    <gazebo reference="base_link">
        <mu1>0.2</mu1>
        <mu2>0.2</mu2>
        <material>Gazebo/Red</material>
    </gazebo>

    <link name="lidar_link">
        <visual>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.1" length="0.1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.1" length="0.1"/>
            </geometry>
        </collision>
        <xacro:inertia_lidar/>   <!-- FIX: added missing inertial block -->
    </link>

    <!-- Lidar joint: body top is at height above base_link origin.
         Visual is offset +0.05 inside lidar_link (cylinder sits on top of body). -->
    <joint name="lidar_joint" type="fixed">
        <origin xyz="0 0 ${height}" rpy="0 -0.35 0"/>
        <parent link="base_link"/>
        <child  link="lidar_link"/>
    </joint>

    <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <topic>scan</topic>
      <update_rate>20</update_rate>
      <gz_frame_id>lidar_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265</min_angle>
            <!-- FIX #4: Corrected max_angle typo (was 3.141459265, missing '5' digit) -->
            <max_angle>3.14159265</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.08</min>
          <max>4.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <always_on>true</always_on>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

    <link name="left_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
            <geometry>
                <cylinder radius="${radius}" length="${d}"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
            <geometry>
                <cylinder radius="${radius}" length="${d}"/>
            </geometry>
        </collision>
        <xacro:inertia_wheel/>
    </link>

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child  link="left_wheel_link"/>
        <origin xyz="${-wheel_x} ${-wheel_y} 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit effort="50000" velocity="10"/>
        <dynamics damping="1.0" friction="1.0"/>
    </joint>

    <gazebo reference="left_wheel_link"> 
        <mu1>0.8</mu1>
        <mu2>0.8</mu2>
        <material>Gazebo/Yellow</material>
    </gazebo>

    <link name="right_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
            <geometry>
                <cylinder radius="${radius}" length="${d}"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
            <geometry>
                <cylinder radius="${radius}" length="${d}"/>
            </geometry>
        </collision>
        <xacro:inertia_wheel/>
    </link>

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child  link="right_wheel_link"/>
        <origin xyz="${-wheel_x} ${wheel_y} 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit effort="50000" velocity="10"/>
        <dynamics damping="1.0" friction="1.0"/>
    </joint>

    <gazebo reference="right_wheel_link">  
        <mu1>0.8</mu1>
        <mu2>0.8</mu2>
        <material>Gazebo/Yellow</material>
    </gazebo>

    <link name="caster1_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
            <geometry>
                <cylinder radius="${radius}" length="${d}"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
            <geometry>
                <cylinder radius="${radius}" length="${d}"/>
            </geometry>
        </collision>
        <xacro:inertia_wheel/>
    </link>

    <joint name="caster1_joint" type="fixed">
        <parent link="base_link"/>
        <child  link="caster1_link"/>
        <origin xyz="${wheel_x} ${-wheel_y} 0" rpy="0 0 0"/>
    </joint>

    <gazebo reference="caster1_link">
        <mu1>0.000002</mu1>
        <mu2>0.000002</mu2>
        <material>Gazebo/Blue</material>
    </gazebo>

    <link name="caster2_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
            <geometry>
                <cylinder radius="${radius}" length="${d}"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
            <geometry>
                <cylinder radius="${radius}" length="${d}"/>
            </geometry>
        </collision>
        <xacro:inertia_wheel/>
    </link>

    <joint name="caster2_joint" type="fixed">
        <parent link="base_link"/>
        <child  link="caster2_link"/>
        <origin xyz="${wheel_x} ${wheel_y} 0" rpy="0 0 0"/>
    </joint>

    <gazebo reference="caster2_link">
        <mu1>0.000002</mu1>
        <mu2>0.000002</mu2>
        <material>Gazebo/Blue</material>
    </gazebo>

    <gazebo>
        <plugin filename="gz-sim-diff-drive-system"
                name="gz::sim::systems::DiffDrive">
            <left_joint>left_wheel_joint</left_joint>
            <right_joint>right_wheel_joint</right_joint>
            <wheel_separation>${2*wheel_y}</wheel_separation>
            <wheel_radius>${radius}</wheel_radius>
            <odom_publish_frequency>20</odom_publish_frequency>
            <topic>cmd_vel</topic>
            <odom_topic>odom</odom_topic>
            <tf_topic>tf</tf_topic>
            <frame_id>odom</frame_id>
            <child_frame_id>base_footprint</child_frame_id>
            <max_linear_acceleration>1.0</max_linear_acceleration>
        </plugin>
    </gazebo>

    <gazebo>
        <plugin filename="gz-sim-joint-state-publisher-system"
                name="gz::sim::systems::JointStatePublisher">
            <joint_name>left_wheel_joint</joint_name>
            <joint_name>right_wheel_joint</joint_name>
            <topic>joint_states</topic>
        </plugin>
    </gazebo>

</robot>